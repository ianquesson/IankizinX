-- COMPONENTE SLIDER HÍBRIDO (DESLIZA + DIGITA)
local function AddSlider(p, txt, key, min, max, def)
    local f = Instance.new("Frame", p); f.Size = UDim2.new(0.95, 0, 0, 65); f.BackgroundColor3 = Color3.fromRGB(20, 28, 55); Instance.new("UICorner", f)
    local l = Instance.new("TextLabel", f); l.Size = UDim2.new(1, 0, 0, 25); l.Position = UDim2.new(0, 12, 0, 5); l.Text = txt; l.TextColor3 = Color3.new(0.9,0.9,0.9); l.Font = Enum.Font.Gotham; l.TextXAlignment = Enum.TextXAlignment.Left; l.BackgroundTransparency = 1
    
    local sbg = Instance.new("TextButton", f); sbg.Size = UDim2.new(0.7, 0, 0, 6); sbg.Position = UDim2.new(0.05, 0, 0, 45); sbg.BackgroundColor3 = Color3.fromRGB(40, 45, 70); sbg.Text = ""; Instance.new("UICorner", sbg)
    local fill = Instance.new("Frame", sbg); fill.Size = UDim2.new((def-min)/(max-min), 0, 1, 0); fill.BackgroundColor3 = Color3.fromRGB(40, 100, 255); Instance.new("UICorner", fill)
    local box = Instance.new("TextBox", f); box.Size = UDim2.new(0, 50, 0, 25); box.Position = UDim2.new(1, -65, 0, 35); box.Text = tostring(def); box.BackgroundColor3 = Color3.fromRGB(30, 35, 60); box.TextColor3 = Color3.new(1,1,1); box.Font = Enum.Font.Gotham; Instance.new("UICorner", box)

    local function update(input)
        local pos = math.clamp((input.Position.X - sbg.AbsolutePosition.X) / sbg.AbsoluteSize.X, 0, 1)
        local val = math.floor(min + (max - min) * pos)
        Configs[key] = val
        box.Text = tostring(val)
        fill.Size = UDim2.new(pos, 0, 1, 0)
    end

    sbg.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then update(input) local move; move = UIS.InputChanged:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseMovement then update(i) end end) UIS.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then move:Disconnect() end end) end end)
    
    box.FocusLost:Connect(function() 
        local v = tonumber(box.Text) or min
        v = math.clamp(v, min, max)
        Configs[key] = v
        box.Text = tostring(v)
        fill:TweenSize(UDim2.new((v-min)/(max-min), 0, 1, 0), "Out", "Quad", 0.2, true)
    end)
end

