-- ESP CODE (SKELETON FIX)
local function CreateESP(p)
    local Line = Drawing.new("Line"); Line.Visible = false; Line.Thickness = 1.5; local Text = Drawing.new("Text"); Text.Visible = false; Text.Size = 14; Text.Center = true; Text.Outline = true
    local Bones = {H=Drawing.new("Line"), LA=Drawing.new("Line"), RA=Drawing.new("Line"), LL=Drawing.new("Line"), RL=Drawing.new("Line")}
    for _,b in pairs(Bones) do b.Thickness = 3.5; b.Visible = false end
    RunService.RenderStepped:Connect(function()
        if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local c = p.Character; local pos, vis = Camera:WorldToViewportPoint(c.HumanoidRootPart.Position); local col = Stroke.Color
            if vis then
                if Configs.ESP_Names then Text.Text = p.Name; Text.Position = Vector2.new(pos.X, pos.Y - 45); Text.Visible = true; Text.Color = col else Text.Visible = false end
                if Configs.ESP_Lines then Line.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y); Line.To = Vector2.new(pos.X, pos.Y); Line.Visible = true; Line.Color = col else Line.Visible = false end
                if Configs.ESP_Skeleton then
                    local function DB(l, p1, p2) local part1 = c:FindFirstChild(p1); local part2 = c:FindFirstChild(p2) if part1 and part2 then local v1, s1 = Camera:WorldToViewportPoint(part1.Position); local v2, s2 = Camera:WorldToViewportPoint(part2.Position) if s1 and s2 then l.From = Vector2.new(v1.X, v1.Y); l.To = Vector2.new(v2.X, v2.Y); l.Visible = true; l.Color = col else l.Visible = false end else l.Visible = false end end
                    DB(Bones.H, "Head", "HumanoidRootPart"); DB(Bones.LA, "HumanoidRootPart", c:FindFirstChild("Left Arm") and "Left Arm" or "LeftUpperArm"); DB(Bones.RA, "HumanoidRootPart", c:FindFirstChild("Right Arm") and "Right Arm" or "RightUpperArm"); DB(Bones.LL, "HumanoidRootPart", c:FindFirstChild("Left Leg") and "Left Leg" or "LeftLowerLeg"); DB(Bones.RL, "HumanoidRootPart", c:FindFirstChild("Right Leg") and "Right Leg" or "RightLowerLeg")
                else for _,b in pairs(Bones) do b.Visible = false end end
            else Line.Visible = false; Text.Visible = false; for _,b in pairs(Bones) do b.Visible = false end end
        else Line.Visible = false; Text.Visible = false; for _,b in pairs(Bones) do b.Visible = false end end
    end)
end
for _,v in pairs(game.Players:GetPlayers()) do if v ~= Player then CreateESP(v) end end
